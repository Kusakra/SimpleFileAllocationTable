{
    "tasks": [
        {
            "type": "cppbuild",
            "label": "C/C++: gcc.exe 生成活动文件",
            "command": "E:\\Dev-Cpp\\MinGW32\\bin\\gcc.exe",
            "args": [
                "-fdiagnostics-color=always",
                "-finput-charset=UTF-8",
                "-fexec-charset=GBK",
                "-g",
                "${workspaceFolder}\\main.c",
                "${workspaceFolder}\\init.c",
                "${workspaceFolder}\\fileio.c",
                "${workspaceFolder}\\path.c",
                "${workspaceFolder}\\dir.c",
                "${workspaceFolder}\\file.c",
                "${workspaceFolder}\\user.c",
                "${workspaceFolder}\\shell.c",
                "-o",
                "${fileDirname}\\${fileBasenameNoExtension}.exe"
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": "build",
            "detail": "调试器生成的任务。"
        }
    ],
    "version": "2.0.0"
}